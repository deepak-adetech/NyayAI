<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- JIT + unsigned memory for Electron renderer -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Network access for syncing to server -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Full read-write access to user-selected files/folders (required for folder picker + watching) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Read-write access to Downloads folder -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!-- Allow reading/watching arbitrary folders the user adds -->
    <key>com.apple.security.files.all</key>
    <true/>
    <!-- Required for chokidar file system events -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
